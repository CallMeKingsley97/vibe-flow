{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Flow",
  "version": "0.1.2",
  "identifier": "dev.vibeflow.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vibe Flow",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "backgroundColor": "#090d14"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Observe local AI coding agent sessions",
    "longDescription": "Vibe Flow reads local Codex, Claude, Gemini and Cursor histories to visualize agent execution flows, commands, tools and risks."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzRTdENDgwNTFFQ0UyNApSV1Fremg0RlNIMCtEbkQ0bC9waEJGSW1DL090T2xLTFpnRmx0aVBDVHBoTlJnLzA2QVF1MXBFZQo=",
      "endpoints": [
        "https://github.com/CallMeKingsley97/vibe-flow/releases/latest/download/latest.json"
      ]
    }
  }
}
